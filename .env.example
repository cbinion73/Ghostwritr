DATABASE_URL="postgresql://postgres:postgres@localhost:5432/book_platform_builder?schema=public"
NEXT_PUBLIC_APP_NAME="Book Platform Builder"
STORAGE_BUCKET="book-platform-assets"
STORAGE_REGION="us-east-1"
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="your-key-here"
ANTHROPIC_API_KEY="your-key-here"
GOOGLE_API_KEY="your-key-here"

# --- Legacy OpenAI per-stage knobs (still read by research.ts for verify/adjudicate) ---
OPENAI_RESEARCH_QUESTION_MODEL="gpt-5.4"
OPENAI_RESEARCH_EXTRACTION_MODEL="gpt-5.4"
OPENAI_RESEARCH_VERIFICATION_MODEL="gpt-5.4"
OPENAI_RESEARCH_QUESTION_REASONING="high"
OPENAI_RESEARCH_EXTRACTION_REASONING="high"
OPENAI_RESEARCH_VERIFICATION_REASONING="high"
OPENAI_RESEARCH_ADJUDICATION_MODEL="gpt-5.4"
OPENAI_RESEARCH_ADJUDICATION_REASONING="xhigh"
OPENAI_EXTERNAL_STORIES_MODEL="gpt-5.4"

# --- Per-stage LLM routing overrides (read by src/lib/llm/routing.ts) ---
# Format: <provider>:<model-id> where provider is anthropic, openai, or google.
# Defaults are in src/lib/llm/routing.ts; env values override per-stage.
#
# External Stories — Claude for narrative extraction + enrichment
LLM_EXTERNAL_STORIES_EXTRACT="anthropic:claude-sonnet-4-6"
LLM_EXTERNAL_STORIES_ENRICH="anthropic:claude-sonnet-4-6"
#
# Research — Claude for questions/extract/adjudicate, OpenAI for cheap verify
LLM_RESEARCH_QUESTIONS="anthropic:claude-sonnet-4-6"
LLM_RESEARCH_EXTRACT="anthropic:claude-sonnet-4-6"
LLM_RESEARCH_VERIFY="openai:gpt-5"
LLM_RESEARCH_ADJUDICATE="anthropic:claude-sonnet-4-6"
#
# Chapter Draft — Opus for the crown jewel (wired in a later pass)
LLM_CHAPTER_DRAFT_AUTHOR="anthropic:claude-opus-4-6"
LLM_CHAPTER_DRAFT_REVISE="anthropic:claude-sonnet-4-6"
#
# Voice Guard — MUST be a different family from the author
LLM_VOICE_GUARD_CRITIC="openai:gpt-5"
#
# Other stages (wired in later passes)
LLM_PROMISE_AUTHOR="anthropic:claude-sonnet-4-6"
LLM_AUDIENCE_AUTHOR="anthropic:claude-sonnet-4-6"
LLM_OUTLINE_AUTHOR="anthropic:claude-sonnet-4-6"
LLM_BASE_STORY_AUTHOR="anthropic:claude-sonnet-4-6"
LLM_PERSONAL_STORIES_INTERVIEW="anthropic:claude-sonnet-4-6"
LLM_MARKET_ANALYSIS_RESEARCH="google:gemini-2.5-pro"
LLM_LENGTH_ADJUSTMENT_AUTHOR="anthropic:claude-sonnet-4-6"
LLM_FINAL_EDITOR_POLISH="anthropic:claude-opus-4-6"
INTERNAL_WORKFLOW_TOKEN="set-a-long-random-string"
WEB_SEARCH_PROVIDERS="serpapi,bing_web_search,duckduckgo_html"
SERPAPI_API_KEY="your-serpapi-key"
SERPAPI_ENGINE="google"
SERPAPI_ENDPOINT="https://serpapi.com/search.json"
BING_WEB_SEARCH_API_KEY="your-bing-web-search-key"
BING_WEB_SEARCH_ENDPOINT="https://api.bing.microsoft.com/v7.0/search"
WEB_SEARCH_TIMEOUT_MS="18000"
WEB_FETCH_TIMEOUT_MS="20000"
