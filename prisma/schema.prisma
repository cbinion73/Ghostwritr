generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum BookStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BookWorkflowType {
  NONFICTION
  FICTION
  WORKBOOK
}

enum StageKey {
  BOOK_SETUP
  PROMISE
  AUDIENCE
  MARKET_ANALYSIS
  STORY_SETUP
  STORY_CORE
  WORLD_CAST
  PLOT_BLUEPRINT
  SCENE_PLAN
  FICTION_DRAFT
  OUTLINE
  BASE_STORY
  RESEARCH
  EXTERNAL_STORIES
  PERSONAL_STORIES
  MANIFEST
  CHAPTER_DRAFT
  EDITING
  TYPESET
  LAUNCH_LISTING
  PRESS_KIT
  SOCIAL_CAMPAIGN
  AUDIO_PREP
  COURSE_DESIGN
  SPEAKING_KIT
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  READY_FOR_REVIEW
  COMMITTED
  BLOCKED
}

enum ArtifactType {
  BOOK_SETUP_PROFILE
  PROMISE_BRIEF
  PROMISE_CHAT
  PERSONA_PACK
  MARKET_REPORT
  POSITIONING_RECOMMENDATIONS
  PROMISE_SCORECARD
  AUDIENCE_RESEARCH
  CORE_TRUTHS
  TRANSFORMATION_ARC
  BOOK_PROMISE_REPORT
  STORY_SETUP_PROFILE
  STORY_CORE_BIBLE
  WORLD_CAST_BIBLE
  FICTION_PLOT_BLUEPRINT
  FICTION_SCENE_PLAN
  FICTION_DRAFT_MANUSCRIPT
  OUTLINE
  OUTLINE_EXPANSION
  CHAPTER_PARAGRAPH_PLAN
  BASE_STORY
  RESEARCH_PACK
  STORY_PACK
  EXTERNAL_STORY_PACK
  PERSONAL_STORY_CHAT
  PERSONAL_STORY_ENCYCLOPEDIA
  CHAPTER_MANIFEST
  CHAPTER_DRAFT
  EDITORIAL_REVIEW
  AI_VOICE_REVIEW
  EDITORIAL_ASSESSMENT
  MANUSCRIPT_REVISION
  MANUSCRIPT_ASSEMBLY
  LENGTH_ADJUSTMENT
  PUBLISHING_PACKAGE
  TYPESET_PACKAGE
  LAUNCH_LISTING_PACKAGE
  PRESS_KIT_PACKAGE
  SOCIAL_CAMPAIGN_PACKAGE
  AUDIO_PREP_PACKAGE
  COURSE_DESIGN_PACKAGE
  SPEAKING_KIT_PACKAGE
  MARKETING_HANDOFF_PACKAGE
  PROVENANCE_REPORT
}

enum ArtifactStatus {
  DRAFT
  REVIEW_READY
  COMMITTED
  SUPERSEDED
}

enum DecisionType {
  ACCEPT
  REJECT
  REQUEST_REVISION
  COMMIT
  REOPEN
}

enum WorkflowRunType {
  PROMISE_CONVERSATION
  PROMISE_EXTRACTION
  PROMISE_SCORING
  PERSONA_ANALYSIS
  MARKET_ANALYSIS
  POSITIONING_RECOMMENDATIONS
  GENERAL
}

enum WorkflowRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum SourceDocumentCategory {
  PROMPT_ARCHIVE
  COMMUNICATION_FRAMEWORK
  USER_UPLOAD
  RESEARCH_REFERENCE
  GENERATED_EXPORT
  GENERATED_SNAPSHOT
}

enum SourceDocumentType {
  FILE
  WEB_PAGE
  GENERATED
}

enum ActorType {
  USER
  SYSTEM
  MODEL
}

enum ResearchSourceTier {
  A
  B
  C
}

enum ResearchVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  NEEDS_CORROBORATION
}

enum ResearchVerifierType {
  FETCH_VALIDATOR
  LLM_VERIFIER
  HUMAN_REVIEW
}

enum ResearchItemType {
  FACT
  STATISTIC
  QUOTE
  EXAMPLE
  CASE_STUDY
  COUNTERPOINT
  DEFINITION
}

enum StorySourceTier {
  A
  B
  C
}

enum StoryVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  NEEDS_CORROBORATION
}

enum StoryVerifierType {
  FETCH_VALIDATOR
  LLM_VERIFIER
  HUMAN_REVIEW
}

enum ExternalStoryType {
  ORIGIN
  TURNING_POINT
  FAILURE
  RECOVERY
  DECISION_UNDER_PRESSURE
  INNOVATION
  CULTURE
  CREDIBILITY
  CONTRADICTION
  MORAL
  LEGACY
  MICRO_STORY
}

enum ExternalStoryFit {
  OPENING_HOOK
  CHAPTER_PIVOT
  PROOF_POINT
  EMOTIONAL_RELEASE
  CLOSING_RESONANCE
  MARKETING_REUSE
}

enum BaseStoryFormat {
  PARABLE
  HERO_JOURNEY
  GUIDE_JOURNEY
  COMPOSITE_CHARACTER
  CASE_JOURNEY
  MOSAIC_VIGNETTES
  QUEST
  RISE_FALL_REDEMPTION
  LETTER_FRAME
  FIELD_MANUAL_NARRATIVE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books          Book[]
  decisions      Decision[]
  directionEvents DirectionEvent[]
  authorProfiles AuthorProfile[]
}

model WriterPersona {
  id                    String   @id @default(uuid()) @db.Uuid
  slug                  String   @unique
  name                  String   @unique
  description           String
  voiceTraitsJson       Json     @default("[]")
  signaturePatternsJson Json     @default("[]")
  avoidPatternsJson     Json     @default("[]")
  frameworkFlowJson     Json     @default("[]")
  frameworkName         String?
  sampleExcerpt         String?
  isBuiltIn             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  samples WriterPersonaSample[]
}

model WriterPersonaSample {
  id                String   @id @default(uuid()) @db.Uuid
  writerPersonaId   String   @db.Uuid
  title             String
  storagePath       String
  mimeType          String
  note              String?
  originalFileName  String?
  byteSize          Int      @default(0)
  useForInspiration Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  writerPersona WriterPersona @relation(fields: [writerPersonaId], references: [id], onDelete: Cascade)

  @@index([writerPersonaId, useForInspiration, createdAt])
}

model Book {
  id           String     @id @default(uuid()) @db.Uuid
  slug         String     @unique
  titleWorking String?
  subtitle     String?
  status       BookStatus @default(DRAFT)
  workflowType BookWorkflowType @default(NONFICTION)
  metadataJson Json       @default("{}")
  ownerUserId  String?    @db.Uuid
  parentBookId String?    @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner           User?            @relation(fields: [ownerUserId], references: [id])
  parentBook      Book?            @relation("CompanionBooks", fields: [parentBookId], references: [id])
  companions      Book[]           @relation("CompanionBooks")
  stages          BookStage[]
  artifacts       Artifact[]
  decisions       Decision[]
  workflowRuns    WorkflowRun[]
  researchTabs    ResearchBinderTab[]
  ideaClips       ResearchIdeaClip[]
  externalStoryTabs ExternalStoryBinderTab[]
  externalStoryClips ExternalStoryClip[]
  researchSources ResearchSource[]
  researchItems   ResearchItem[]
  researchChecks  ResearchVerification[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]
  externalStoryChecks ExternalStoryVerification[]
  sourceDocuments SourceDocument[]
  directionEvents DirectionEvent[]
}

model BookStage {
  id                         String      @id @default(uuid()) @db.Uuid
  bookId                     String      @db.Uuid
  stageKey                   StageKey
  status                     StageStatus @default(NOT_STARTED)
  activeArtifactVersionId    String?     @db.Uuid
  committedArtifactVersionId String?     @db.Uuid
  metadataJson               Json        @default("{}")
  startedAt                  DateTime?
  committedAt                DateTime?
  updatedAt                  DateTime    @updatedAt
  createdAt                  DateTime    @default(now())

  book         Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  artifacts    Artifact[]
  decisions    Decision[]
  researchTabs ResearchBinderTab[]
  ideaClips ResearchIdeaClip[]
  externalStoryTabs ExternalStoryBinderTab[]
  externalStoryClips ExternalStoryClip[]
  researchSources ResearchSource[]
  researchItems ResearchItem[]
  researchChecks ResearchVerification[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]
  externalStoryChecks ExternalStoryVerification[]
  workflowRuns WorkflowRun[]
  directionEvents DirectionEvent[]

  @@unique([bookId, stageKey])
  @@index([bookId, stageKey])
}

model DirectionEvent {
  id              String    @id @default(uuid()) @db.Uuid
  bookId          String    @db.Uuid
  stageId         String    @db.Uuid
  artifactId      String?   @db.Uuid
  eventType       String
  actorType       ActorType
  actorUserId     String?   @db.Uuid
  title           String
  content         String?
  metadataJson    Json      @default("{}")
  createdAt       DateTime  @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  artifact  Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  actorUser  User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookId, stageId, createdAt])
  @@index([eventType, actorType])
}

model Artifact {
  id                 String         @id @default(uuid()) @db.Uuid
  bookId             String         @db.Uuid
  stageId            String         @db.Uuid
  artifactType       ArtifactType
  status             ArtifactStatus @default(DRAFT)
  currentVersionId   String?        @db.Uuid
  committedVersionId String?        @db.Uuid
  title              String?
  summary            String?
  metadataJson       Json           @default("{}")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  book      Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  versions  ArtifactVersion[]
  decisions Decision[]
  directionEvents DirectionEvent[]

  @@index([bookId, stageId, artifactType])
}

model ArtifactVersion {
  id                    String         @id @default(uuid()) @db.Uuid
  artifactId            String         @db.Uuid
  versionNumber         Int
  lifecycleState        ArtifactStatus @default(DRAFT)
  contentJson           Json           @default("{}")
  contentText           String?
  summary               String?
  createdByType         ActorType
  createdByUserId       String?        @db.Uuid
  workflowRunId         String?        @db.Uuid
  basedOnVersionIdsJson Json           @default("[]")
  promptTemplateVersion String?
  modelName             String?
  committedAt           DateTime?
  createdAt             DateTime       @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  researchSources ResearchSource[]
  researchItems ResearchItem[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]

  @@unique([artifactId, versionNumber])
  @@index([artifactId, lifecycleState])
}

model Decision {
  id              String       @id @default(uuid()) @db.Uuid
  bookId          String       @db.Uuid
  stageId         String       @db.Uuid
  artifactId      String?      @db.Uuid
  decisionType    DecisionType
  decisionValue   String
  notes           String?
  metadataJson    Json         @default("{}")
  createdByUserId String       @db.Uuid
  createdAt       DateTime     @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  artifact  Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([bookId, stageId, createdAt])
}

model WorkflowRun {
  id         String            @id @default(uuid()) @db.Uuid
  bookId     String            @db.Uuid
  stageId    String            @db.Uuid
  runType    WorkflowRunType   @default(GENERAL)
  status     WorkflowRunStatus @default(QUEUED)
  inputJson  Json              @default("{}")
  outputJson Json              @default("{}")
  errorText  String?
  startedAt  DateTime          @default(now())
  finishedAt DateTime?

  book  Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([bookId, stageId, status])
}

model SourceDocument {
  id             String                 @id @default(uuid()) @db.Uuid
  bookId         String?                @db.Uuid
  category       SourceDocumentCategory
  sourceType     SourceDocumentType     @default(FILE)
  title          String
  storagePath    String
  mimeType       String
  sourceUrl      String?
  metadataJson   Json                   @default("{}")
  extractedText  String?
  embeddingState String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, category])
}

model ResearchSource {
  id                       String                     @id @default(uuid()) @db.Uuid
  bookId                   String                     @db.Uuid
  stageId                  String                     @db.Uuid
  researchArtifactVersionId String?                   @db.Uuid
  chapterKey               String
  url                      String
  canonicalUrl             String?
  title                    String
  publisher                String?
  author                   String?
  publishedAt              DateTime?
  accessedAt               DateTime                   @default(now())
  contentType              String?
  sourceTier               ResearchSourceTier
  tierWeight               Decimal                    @db.Decimal(4, 2)
  isVerified               Boolean                    @default(false)
  verificationStatus       ResearchVerificationStatus @default(PENDING)
  verificationNotes        String?
  snapshotPath             String?
  extractedTextPath        String?
  metadataJson             Json                       @default("{}")
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  book                   Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage                  BookStage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  researchArtifactVersion ArtifactVersion?  @relation(fields: [researchArtifactVersionId], references: [id], onDelete: SetNull)
  researchItems          ResearchItem[]
  verifications          ResearchVerification[]

  @@index([bookId, stageId, chapterKey])
  @@index([researchArtifactVersionId])
  @@index([sourceTier, verificationStatus])
}

model ResearchItem {
  id                       String                     @id @default(uuid()) @db.Uuid
  bookId                   String                     @db.Uuid
  stageId                  String                     @db.Uuid
  researchArtifactVersionId String?                   @db.Uuid
  sourceRecordId           String                     @db.Uuid
  chapterKey               String
  itemType                 ResearchItemType
  claimText                String
  evidenceExcerpt          String?
  summary                  String?
  sourceTier               ResearchSourceTier
  tierWeight               Decimal                    @db.Decimal(4, 2)
  verificationStatus       ResearchVerificationStatus @default(PENDING)
  verifiedByRunId          String?                    @db.Uuid
  relevanceScore           Decimal?                   @db.Decimal(4, 2)
  confidenceScore          Decimal?                   @db.Decimal(4, 2)
  mappedSectionId          String?
  mappedChapterId          String?
  mappedParagraphId        String?
  metadataJson             Json                       @default("{}")
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  book                   Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage                  BookStage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  researchArtifactVersion ArtifactVersion?  @relation(fields: [researchArtifactVersionId], references: [id], onDelete: SetNull)
  sourceRecord           ResearchSource     @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  verifications          ResearchVerification[]

  @@index([bookId, stageId, chapterKey])
  @@index([researchArtifactVersionId])
  @@index([sourceRecordId, verificationStatus])
}

model ResearchVerification {
  id                    String                     @id @default(uuid()) @db.Uuid
  bookId                String                     @db.Uuid
  stageId               String                     @db.Uuid
  chapterKey            String
  sourceRecordId        String?                    @db.Uuid
  researchItemId        String?                    @db.Uuid
  verifierType          ResearchVerifierType
  status                ResearchVerificationStatus @default(PENDING)
  titleMatch            Boolean?
  contentMatch          Boolean?
  claimSupported        Boolean?
  tierConfirmed         Boolean?
  secondSourceRequired  Boolean                    @default(false)
  secondSourceConfirmed Boolean                    @default(false)
  notes                 String?
  metadataJson          Json                       @default("{}")
  createdAt             DateTime                   @default(now())

  book         Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage        BookStage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  sourceRecord ResearchSource? @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  researchItem ResearchItem?  @relation(fields: [researchItemId], references: [id], onDelete: Cascade)

  @@index([bookId, stageId, chapterKey])
  @@index([sourceRecordId])
  @@index([researchItemId])
  @@index([status, verifierType])
}

model ResearchBinderTab {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @db.Uuid
  stageId      String   @db.Uuid
  label        String
  colorToken   String
  orderIndex   Int      @default(0)
  chapterKeysJson Json  @default("[]")
  metadataJson Json     @default("{}")
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book      Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  ideaClips ResearchIdeaClip[]

  @@index([bookId, stageId, isArchived, orderIndex])
}

model ResearchIdeaClip {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @db.Uuid
  stageId      String   @db.Uuid
  binderTabId  String   @db.Uuid
  chapterKey   String?
  title        String?
  content      String
  orderIndex   Int      @default(0)
  metadataJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book      Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  binderTab ResearchBinderTab @relation(fields: [binderTabId], references: [id], onDelete: Cascade)

  @@index([bookId, stageId, binderTabId, orderIndex])
}

model ExternalStoryBinderTab {
  id              String   @id @default(uuid()) @db.Uuid
  bookId          String   @db.Uuid
  stageId         String   @db.Uuid
  label           String
  colorToken      String
  orderIndex      Int      @default(0)
  chapterKeysJson Json     @default("[]")
  metadataJson    Json     @default("{}")
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  book       Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage      BookStage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  storyClips ExternalStoryClip[]

  @@index([bookId, stageId, isArchived, orderIndex])
}

model ExternalStoryClip {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @db.Uuid
  stageId      String   @db.Uuid
  binderTabId  String   @db.Uuid
  chapterKey   String?
  title        String?
  content      String
  orderIndex   Int      @default(0)
  metadataJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book      Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage             @relation(fields: [stageId], references: [id], onDelete: Cascade)
  binderTab ExternalStoryBinderTab @relation(fields: [binderTabId], references: [id], onDelete: Cascade)

  @@index([bookId, stageId, binderTabId, orderIndex])
}

model ExternalStorySource {
  id                     String                  @id @default(uuid()) @db.Uuid
  bookId                 String                  @db.Uuid
  stageId                String                  @db.Uuid
  storyArtifactVersionId String?                 @db.Uuid
  chapterKey             String
  url                    String
  canonicalUrl           String?
  title                  String
  publisher              String?
  author                 String?
  publishedAt            DateTime?
  accessedAt             DateTime                @default(now())
  contentType            String?
  sourceTier             StorySourceTier
  tierWeight             Decimal                 @db.Decimal(4, 2)
  isVerified             Boolean                 @default(false)
  verificationStatus     StoryVerificationStatus @default(PENDING)
  verificationNotes      String?
  snapshotPath           String?
  extractedTextPath      String?
  metadataJson           Json                    @default("{}")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  book                 Book                      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage                BookStage                 @relation(fields: [stageId], references: [id], onDelete: Cascade)
  storyArtifactVersion ArtifactVersion?          @relation(fields: [storyArtifactVersionId], references: [id], onDelete: SetNull)
  storyItems           ExternalStoryItem[]
  verifications        ExternalStoryVerification[]

  @@index([bookId, stageId, chapterKey])
  @@index([storyArtifactVersionId])
  @@index([sourceTier, verificationStatus])
}

model ExternalStoryItem {
  id                     String                  @id @default(uuid()) @db.Uuid
  bookId                 String                  @db.Uuid
  stageId                String                  @db.Uuid
  storyArtifactVersionId String?                 @db.Uuid
  sourceRecordId         String                  @db.Uuid
  chapterKey             String
  title                  String
  summary                String
  whyItMatters           String
  emotionalRole          String
  storyType              ExternalStoryType
  storyFit               ExternalStoryFit
  leadershipTheme        String?
  sourceTier             StorySourceTier
  tierWeight             Decimal                 @db.Decimal(4, 2)
  verificationStatus     StoryVerificationStatus @default(PENDING)
  mappedSectionId        String?
  mappedChapterId        String?
  metadataJson           Json                    @default("{}")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  book                 Book                      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage                BookStage                 @relation(fields: [stageId], references: [id], onDelete: Cascade)
  storyArtifactVersion ArtifactVersion?          @relation(fields: [storyArtifactVersionId], references: [id], onDelete: SetNull)
  sourceRecord         ExternalStorySource       @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  verifications        ExternalStoryVerification[]

  @@index([bookId, stageId, chapterKey])
  @@index([storyArtifactVersionId])
  @@index([sourceRecordId, verificationStatus])
}

model ExternalStoryVerification {
  id                    String                  @id @default(uuid()) @db.Uuid
  bookId                String                  @db.Uuid
  stageId               String                  @db.Uuid
  chapterKey            String
  sourceRecordId        String?                 @db.Uuid
  externalStoryId       String?                 @db.Uuid
  verifierType          StoryVerifierType
  status                StoryVerificationStatus @default(PENDING)
  titleMatch            Boolean?
  contentMatch          Boolean?
  claimSupported        Boolean?
  secondSourceRequired  Boolean                 @default(false)
  secondSourceConfirmed Boolean                 @default(false)
  notes                 String?
  metadataJson          Json                    @default("{}")
  createdAt             DateTime                @default(now())

  book          Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage         BookStage            @relation(fields: [stageId], references: [id], onDelete: Cascade)
  sourceRecord  ExternalStorySource? @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  externalStory ExternalStoryItem?   @relation(fields: [externalStoryId], references: [id], onDelete: Cascade)

  @@index([bookId, stageId, chapterKey])
  @@index([sourceRecordId])
  @@index([externalStoryId])
  @@index([status, verifierType])
}

model LLMCallLog {
  id               String   @id @default(uuid()) @db.Uuid
  bookId           String   @db.Uuid
  workflowRunId    String?  @db.Uuid
  stageRole        String
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Decimal  @db.Decimal(10, 6)
  durationMs       Int
  createdAt        DateTime @default(now())

  @@index([bookId, createdAt])
  @@index([bookId, stageRole])
}

/// Author Profile - Persistent author information across books
/// Stores background, writing preferences, constraints, and brand voice
/// Linked to User and optionally to BookSetupProfile for personalization
model AuthorProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String?   @db.Uuid

  // Core Information
  displayName           String    // How author wants to be called
  backgroundSummary     String?   // 200-300 word biography/background
  expertise             Json      @default("[]")  // Array of expertise areas
  targetAudience        String?   // Description of typical audience

  // Writing Preferences
  tonePreference        String?   // e.g., "Direct, practical, slightly irreverent"
  proseStyle            String?   // e.g., "Clear structure, avoid flowery language"
  preferredMetaphors    Json      @default("[]")  // Array of preferred metaphor types

  // Values & Constraints
  avoidPatterns         Json      @default("[]")  // Array of things to avoid
  mustInclude           Json      @default("[]")  // Array of things to always include
  brandVoice            String?   // Overall brand voice description

  // Multi-Book Consistency (for series/related books)
  characterNames        Json      @default("[]")  // Array of character names (consistency across books)
  terminology           Json      @default("[]")  // Array of custom glossary terms
  recurringMetaphors    Json      @default("[]")  // Array of metaphors to repeat
  styleGuideNotes       String?   // Custom formatting, structure notes

  // Metadata
  isDefault             Boolean   @default(false) // Can have multiple profiles, one default
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isDefault])
}
