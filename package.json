{
  "name": "ghostwritr",
  "private": true,
  "version": "0.1.0",
  "description": "Book research and ghostwriting platform",
  "scripts": {
    "check": "tsc --noEmit --pretty false",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "db:seed:references": "tsx prisma/seed-reference-books.ts",
    "qa:e2e:battery": "node scripts/e2e-battery.mjs",
    "qa:e2e:audit": "node scripts/e2e-audit.mjs",
    "qa:full-system": "node scripts/full-system-regression.mjs",
    "qa:fiction-publish": "node scripts/fiction-publish-regression.mjs",
    "qa:fiction-scene-focus": "tsx scripts/fiction-scene-focus-regression.ts",
    "qa:nonfiction": "node scripts/nonfiction-regression.mjs",
    "qa:archive": "tsx scripts/archive-roundtrip-regression.ts",
    "qa:artifact-contracts": "tsx scripts/artifact-contract-regression.ts",
    "qa:autopilot": "tsx scripts/autopilot-regression.ts",
    "qa:editing-trust": "tsx scripts/editing-trust-regression.ts",
    "qa:publication-pass": "tsx --test tests/publication-pass.test.ts tests/chapter-integrity.test.ts",
    "qa:manuscript-length": "tsx scripts/manuscript-length-regression.ts",
    "qa:promise-phase2": "tsx scripts/promise-phase2-regression.ts",
    "qa:prod-runtime": "node tests/production-runtime-smoke.mjs",
    "qa:stale-dependencies": "tsx scripts/stale-dependency-regression.ts",
    "qa:source-citations": "GHOSTWRITR_LIVE_LLM_TESTS=0 GHOSTWRITR_SOURCE_QA=1 tsx --test tests/source-verification-engine.test.ts tests/source-verification-admission.test.ts tests/source-evidence-contract.test.ts tests/source-citation-safe-rollout.test.ts tests/citation-audit-engine.test.ts tests/citation-audit-contracts.test.ts tests/citation-publication-rendering.test.ts tests/database-integrity-contracts.test.ts tests/api-route-contracts.test.ts tests/dependency-invalidation.test.ts tests/workflow-durable-jobs.test.ts tests/llm-budget.test.ts",
    "qa:workspace-warnings": "tsx scripts/workspace-warning-regression.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed:flows": "tsx prisma/seed-framework-flows.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.12.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.2",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.5",
    "@prisma/client": "^6.16.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "docx": "^9.6.1",
    "langchain": "^1.5.3",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^6.16.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.10",
    "langsmith": "^0.8.1",
    "postcss": "^8.5.18"
  }
}
