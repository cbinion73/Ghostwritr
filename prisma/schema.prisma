generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum BookStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BookWorkflowType {
  NONFICTION
  FICTION
  WORKBOOK
}

enum StageKey {
  BOOK_SETUP
  PROMISE
  MARKET_ANALYSIS
  STORY_SETUP
  STORY_CORE
  WORLD_CAST
  PLOT_BLUEPRINT
  SCENE_PLAN
  FICTION_DRAFT
  OUTLINE
  BASE_STORY
  RESEARCH
  EXTERNAL_STORIES
  PERSONAL_STORIES
  MANIFEST
  CHAPTER_DRAFT
  WORKBOOK_DESIGN
  EDITING
  CITATION_AUDIT
  TYPESET
  AUDIO_PREP
  COURSE_DESIGN
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  READY_FOR_REVIEW
  COMMITTED
  BLOCKED
}

enum ArtifactType {
  BOOK_SETUP_PROFILE
  PROMISE_BRIEF
  PROMISE_CHAT
  PERSONA_PACK
  MARKET_REPORT
  POSITIONING_RECOMMENDATIONS
  PROMISE_SCORECARD
  AUDIENCE_RESEARCH
  CORE_TRUTHS
  TRANSFORMATION_ARC
  BOOK_PROMISE_REPORT
  PHASE1_STRATEGIC_BRIEF
  STORY_SETUP_PROFILE
  STORY_CORE_BIBLE
  WORLD_CAST_BIBLE
  FICTION_PLOT_BLUEPRINT
  FICTION_SCENE_PLAN
  FICTION_DRAFT_MANUSCRIPT
  OUTLINE
  OUTLINE_EXPANSION
  CHAPTER_PARAGRAPH_PLAN
  BASE_STORY
  RESEARCH_PACK
  STORY_PACK
  EXTERNAL_STORY_PACK
  PERSONAL_STORY_CHAT
  PERSONAL_STORY_ENCYCLOPEDIA
  CHAPTER_MANIFEST
  CHAPTER_DRAFT
  EDITORIAL_REVIEW
  AI_VOICE_REVIEW
  EDITORIAL_ASSESSMENT
  MANUSCRIPT_REVISION
  MANUSCRIPT_ASSEMBLY
  CITATION_AUDIT_REPORT
  CITATION_LEDGER
  LENGTH_ADJUSTMENT
  PUBLISHING_PACKAGE
  TYPESET_PACKAGE
  LAUNCH_LISTING_PACKAGE
  PRESS_KIT_PACKAGE
  SOCIAL_CAMPAIGN_PACKAGE
  AUDIO_PREP_PACKAGE
  COURSE_DESIGN_PACKAGE
  SPEAKING_KIT_PACKAGE
  MARKETING_HANDOFF_PACKAGE
  PROVENANCE_REPORT
}

enum ArtifactStatus {
  DRAFT
  REVIEW_READY
  COMMITTED
  SUPERSEDED
}

enum ChapterApprovalStatus {
  DRAFT_PENDING
  DRAFT_APPROVED
  FINAL_REVISION_PENDING
  FINAL_REVISION_APPROVED
  STALE
}

enum DecisionType {
  ACCEPT
  REJECT
  REQUEST_REVISION
  COMMIT
  REOPEN
}

enum WorkflowRunType {
  PROMISE_CONVERSATION
  PROMISE_EXTRACTION
  PROMISE_SCORING
  PERSONA_ANALYSIS
  MARKET_ANALYSIS
  POSITIONING_RECOMMENDATIONS
  GENERAL
}

enum CitationStyle {
  CHICAGO_17
  APA_7
  MLA_9
}

enum CitationAuditFindingKind {
  SUPPORTED
  MISSING_SOURCE
  INACCESSIBLE
  CONTRADICTED
  DISTORTED
  UNSUPPORTED
  UNUSED
}

enum CitationAuditDecision {
  APPROVE
  MANUAL_EXCEPTION
  REQUEST_REVISION
  REOPEN
}

enum CitationAuditChapterStatus {
  PENDING
  READY_FOR_REVIEW
  APPROVED
  BLOCKED
  STALE
}

enum WorkflowRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum SourceDocumentCategory {
  PROMPT_ARCHIVE
  COMMUNICATION_FRAMEWORK
  USER_UPLOAD
  RESEARCH_REFERENCE
  GENERATED_EXPORT
  GENERATED_SNAPSHOT
}

enum SourceDocumentType {
  FILE
  WEB_PAGE
  GENERATED
}

enum ActorType {
  USER
  SYSTEM
  MODEL
}

enum ResearchSourceTier {
  A
  B
  C
}

enum ResearchVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  NEEDS_CORROBORATION
}

enum ResearchVerifierType {
  FETCH_VALIDATOR
  LLM_VERIFIER
  ADVERSARIAL_VERIFIER
  HUMAN_REVIEW
}

enum ResearchItemType {
  FACT
  STATISTIC
  QUOTE
  EXAMPLE
  CASE_STUDY
  COUNTERPOINT
  DEFINITION
}

enum StorySourceTier {
  A
  B
  C
}

enum StoryVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  NEEDS_CORROBORATION
}

enum StoryVerifierType {
  FETCH_VALIDATOR
  LLM_VERIFIER
  ADVERSARIAL_VERIFIER
  HUMAN_REVIEW
}

enum SourceEvidenceKind {
  RESEARCH_CLAIM
  EXTERNAL_STORY
}

enum SourceVerificationVerdict {
  VERIFIED
  VERIFIED_WITH_CORRECTION
  NEEDS_CORROBORATION
  NOT_FOUND
  INACCESSIBLE
  CONTRADICTED
  REJECTED
}

enum SourceAdmissionDecision {
  APPROVE
  APPROVE_CORRECTED
  REQUEST_CORROBORATION
  REJECT
  MANUAL_EXCEPTION
  REOPEN
}

enum ExternalStoryType {
  ORIGIN
  TURNING_POINT
  FAILURE
  RECOVERY
  DECISION_UNDER_PRESSURE
  INNOVATION
  CULTURE
  CREDIBILITY
  CONTRADICTION
  MORAL
  LEGACY
  MICRO_STORY
}

enum ExternalStoryFit {
  OPENING_HOOK
  CHAPTER_PIVOT
  PROOF_POINT
  EMOTIONAL_RELEASE
  CLOSING_RESONANCE
  MARKETING_REUSE
}

enum BaseStoryFormat {
  PARABLE
  HERO_JOURNEY
  GUIDE_JOURNEY
  COMPOSITE_CHARACTER
  CASE_JOURNEY
  MOSAIC_VIGNETTES
  QUEST
  RISE_FALL_REDEMPTION
  LETTER_FRAME
  FIELD_MANUAL_NARRATIVE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books          Book[]
  decisions      Decision[]
  directionEvents DirectionEvent[]
  authorProfiles AuthorProfile[]
  sourceAdmissionReviews SourceAdmissionReview[]
  citationAuditReviews CitationAuditReview[]
  citationLedgers CitationLedger[]
  citationAuditChapterApprovals CitationAuditChapterState[]
}

model WriterPersona {
  id                    String   @id @default(uuid()) @db.Uuid
  slug                  String   @unique
  name                  String   @unique
  description           String
  voiceTraitsJson       Json     @default("[]")
  signaturePatternsJson Json     @default("[]")
  avoidPatternsJson     Json     @default("[]")
  frameworkFlowJson     Json     @default("[]")
  frameworkName         String?
  sampleExcerpt         String?
  isBuiltIn             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  samples WriterPersonaSample[]
}

model WriterPersonaSample {
  id                String   @id @default(uuid()) @db.Uuid
  writerPersonaId   String   @db.Uuid
  title             String
  storagePath       String
  mimeType          String
  note              String?
  originalFileName  String?
  byteSize          Int      @default(0)
  useForInspiration Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  writerPersona WriterPersona @relation(fields: [writerPersonaId], references: [id], onDelete: Cascade)

  @@index([writerPersonaId, useForInspiration, createdAt])
}

model Book {
  id           String     @id @default(uuid()) @db.Uuid
  slug         String     @unique
  titleWorking String?
  subtitle     String?
  status       BookStatus @default(DRAFT)
  workflowType BookWorkflowType @default(NONFICTION)
  citationStyle CitationStyle @default(CHICAGO_17)
  metadataJson Json       @default("{}")
  ownerUserId  String?    @db.Uuid
  parentBookId String?    @db.Uuid
  /// A real, designed spine photo/graphic uploaded for this book — when set,
  /// the Library shelf renders it as-is instead of the procedural binding.
  coverImageUrl String?
  /// Soft archive — hidden from the library shelf, restorable anytime.
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner           User?            @relation(fields: [ownerUserId], references: [id])
  parentBook      Book?            @relation("CompanionBooks", fields: [parentBookId], references: [id])
  companions      Book[]           @relation("CompanionBooks")
  stages          BookStage[]
  artifacts       Artifact[]
  decisions       Decision[]
  workflowRuns    WorkflowRun[]
  stageOperationalStates StageOperationalState[]
  researchTabs    ResearchBinderTab[]
  ideaClips       ResearchIdeaClip[]
  externalStoryTabs ExternalStoryBinderTab[]
  externalStoryClips ExternalStoryClip[]
  researchSources ResearchSource[]
  researchItems   ResearchItem[]
  researchChecks  ResearchVerification[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]
  externalStoryChecks ExternalStoryVerification[]
  sourceDocuments SourceDocument[]
  directionEvents DirectionEvent[]
  llmBudgetState BookLLMBudgetState?
  agentChatMessages AgentChatMessage[]
  chapterApprovalStates ChapterApprovalState[]
  sourceVerificationResults SourceVerificationResult[]
  sourceAdmissionDecisions SourceAdmissionReview[]
  citationAuditFindings CitationAuditFinding[]
  citationAuditReviews CitationAuditReview[]
  citationAuditChapterStates CitationAuditChapterState[]
  citationLedgers CitationLedger[]
}

model BookStage {
  id                         String      @id @default(uuid()) @db.Uuid
  bookId                     String      @db.Uuid
  stageKey                   StageKey
  status                     StageStatus @default(NOT_STARTED)
  activeArtifactVersionId    String?     @db.Uuid
  committedArtifactVersionId String?     @db.Uuid
  metadataJson               Json        @default("{}")
  startedAt                  DateTime?
  committedAt                DateTime?
  updatedAt                  DateTime    @updatedAt
  createdAt                  DateTime    @default(now())

  book         Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  artifacts    Artifact[]
  decisions    Decision[]
  researchTabs ResearchBinderTab[]
  ideaClips ResearchIdeaClip[]
  externalStoryTabs ExternalStoryBinderTab[]
  externalStoryClips ExternalStoryClip[]
  researchSources ResearchSource[]
  researchItems ResearchItem[]
  researchChecks ResearchVerification[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]
  externalStoryChecks ExternalStoryVerification[]
  workflowRuns WorkflowRun[]
  operationalState StageOperationalState?
  directionEvents DirectionEvent[]
  agentChatMessages AgentChatMessage[]

  @@unique([bookId, stageKey])
  @@index([bookId, stageKey])
}

model BookLLMBudgetState {
  id                  String   @id @default(uuid()) @db.Uuid
  bookId              String   @unique @db.Uuid
  warningUsd          Decimal  @default(10) @db.Decimal(10, 2)
  confirmationUsd     Decimal  @default(20) @db.Decimal(10, 2)
  hardStopUsd         Decimal  @default(30) @db.Decimal(10, 2)
  confirmedThroughUsd Decimal? @db.Decimal(10, 2)
  confirmedAt         DateTime?
  confirmedBy         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model AgentChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  bookId     String   @db.Uuid
  stageId    String   @db.Uuid
  role       String
  content    String
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book  Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, orderIndex])
  @@index([bookId, stageId, orderIndex])
}

model StageOperationalState {
  id                  String   @id @default(uuid()) @db.Uuid
  bookId              String   @db.Uuid
  stageId             String   @unique @db.Uuid
  automationStatus    String?
  currentAction       String?
  currentChapterKey   String?
  totalChapters       Int      @default(0)
  completedChapters   Int      @default(0)
  failedChapters      Json     @default("[]")
  provisionalChapters Json     @default("[]")
  recentActivity      Json     @default("[]")
  selectedFormat      String?
  errorMessage        String?
  lastRunAt           DateTime?
  automationEnabled   Boolean?
  automationMode      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  book  Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([bookId, stageId])
  @@index([automationStatus])
}

model DirectionEvent {
  id              String    @id @default(uuid()) @db.Uuid
  bookId          String    @db.Uuid
  stageId         String    @db.Uuid
  artifactId      String?   @db.Uuid
  eventType       String
  actorType       ActorType
  actorUserId     String?   @db.Uuid
  title           String
  content         String?
  metadataJson    Json      @default("{}")
  createdAt       DateTime  @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  artifact  Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  actorUser  User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookId, stageId, createdAt])
  @@index([eventType, actorType])
}

model Artifact {
  id                 String         @id @default(uuid()) @db.Uuid
  bookId             String         @db.Uuid
  stageId            String         @db.Uuid
  artifactType       ArtifactType
  status             ArtifactStatus @default(DRAFT)
  currentVersionId   String?        @db.Uuid
  committedVersionId String?        @db.Uuid
  chapterId          String?
  title              String?
  summary            String?
  metadataJson       Json           @default("{}")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  book      Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  versions  ArtifactVersion[]
  decisions Decision[]
  directionEvents DirectionEvent[]

  @@index([bookId, stageId, artifactType])
  @@index([bookId, stageId, artifactType, chapterId], map: "Artifact_book_stage_type_chapterId_idx")
}

model ArtifactVersion {
  id                    String         @id @default(uuid()) @db.Uuid
  artifactId            String         @db.Uuid
  versionNumber         Int
  lifecycleState        ArtifactStatus @default(DRAFT)
  contentJson           Json           @default("{}")
  contentText           String?
  summary               String?
  createdByType         ActorType
  createdByUserId       String?        @db.Uuid
  workflowRunId         String?        @db.Uuid
  basedOnVersionIdsJson Json           @default("[]")
  promptTemplateVersion String?
  modelName             String?
  committedAt           DateTime?
  createdAt             DateTime       @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  researchSources ResearchSource[]
  researchItems ResearchItem[]
  externalStorySources ExternalStorySource[]
  externalStoryItems ExternalStoryItem[]
  sourceVerificationResults SourceVerificationResult[]
  citationAuditFindings CitationAuditFinding[] @relation("CitationFindingFinalVersion")
  citationAuditReviews CitationAuditReview[] @relation("CitationReviewFinalVersion")
  citationAuditStates CitationAuditChapterState[] @relation("CitationStateFinalVersion")
  sourceAdmissionReviews SourceAdmissionReview[]

  @@unique([artifactId, versionNumber])
  @@index([artifactId, lifecycleState])
}

model ChapterApprovalState {
  id                            String                @id @default(uuid()) @db.Uuid
  bookId                        String                @db.Uuid
  chapterId                     String
  status                        ChapterApprovalStatus @default(DRAFT_PENDING)
  draftPendingVersionId         String?               @db.Uuid
  approvedDraftVersionId        String?               @db.Uuid
  finalRevisionPendingVersionId String?               @db.Uuid
  approvedFinalVersionId        String?               @db.Uuid
  isStale                       Boolean               @default(false)
  staleReason                   String?
  staleAt                       DateTime?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterId])
  @@index([bookId, status])
  @@index([bookId, isStale])
  @@index([draftPendingVersionId])
  @@index([approvedDraftVersionId])
  @@index([finalRevisionPendingVersionId])
  @@index([approvedFinalVersionId])
}

model CitationAuditFinding {
  id                       String                   @id @default(uuid()) @db.Uuid
  bookId                   String                   @db.Uuid
  chapterKey               String
  approvedFinalVersionId   String                   @db.Uuid
  claimText                String
  claimStart               Int
  claimEnd                 Int
  claimFingerprint         String
  sourceLedgerFingerprint  String
  policyVersion            String
  findingFingerprint       String
  kind                     CitationAuditFindingKind
  evidenceKind             SourceEvidenceKind?
  evidenceRecordId         String?
  sourceRecordId           String?                  @db.Uuid
  supportingExcerpt        String?
  notes                    String?
  workflowRunId            String?                  @db.Uuid
  createdAt                DateTime                 @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reviews CitationAuditReview[]
  approvedFinalVersion ArtifactVersion @relation("CitationFindingFinalVersion", fields: [approvedFinalVersionId], references: [id], onDelete: Restrict)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@unique([bookId, chapterKey, approvedFinalVersionId, findingFingerprint], map: "CitationAuditFinding_exact_fingerprint_key")
  @@index([bookId, chapterKey, approvedFinalVersionId, createdAt], map: "CitationAuditFinding_chapter_version_idx")
  @@index([workflowRunId])
}

model CitationAuditReview {
  id                       String                @id @default(uuid()) @db.Uuid
  bookId                   String                @db.Uuid
  chapterKey               String
  findingId                String?               @db.Uuid
  approvedFinalVersionId   String                @db.Uuid
  findingFingerprint       String
  sourceLedgerFingerprint  String
  policyVersion            String
  decision                 CitationAuditDecision
  reviewerUserId           String?               @db.Uuid
  reason                   String?
  createdAt                DateTime               @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  finding CitationAuditFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)
  reviewer User? @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)
  approvedFinalVersion ArtifactVersion @relation("CitationReviewFinalVersion", fields: [approvedFinalVersionId], references: [id], onDelete: Restrict)

  @@index([bookId, chapterKey, createdAt], map: "CitationAuditReview_chapter_created_idx")
  @@index([findingFingerprint, createdAt], map: "CitationAuditReview_fingerprint_created_idx")
}

model CitationAuditChapterState {
  id                       String                     @id @default(uuid()) @db.Uuid
  bookId                   String                     @db.Uuid
  chapterKey               String
  approvedFinalVersionId   String                     @db.Uuid
  sourceLedgerFingerprint  String
  policyVersion            String
  citationStyle            CitationStyle
  auditFingerprint         String
  currentWorkflowRunId     String?                    @db.Uuid
  status                   CitationAuditChapterStatus @default(PENDING)
  approvedAt               DateTime?
  approvedByUserId         String?                    @db.Uuid
  staleReason              String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  approvedFinalVersion ArtifactVersion @relation("CitationStateFinalVersion", fields: [approvedFinalVersionId], references: [id], onDelete: Restrict)
  currentWorkflowRun WorkflowRun? @relation(fields: [currentWorkflowRunId], references: [id], onDelete: SetNull)
  approvedByUser User? @relation(fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([bookId, chapterKey])
  @@index([bookId, status])
  @@index([approvedFinalVersionId, auditFingerprint])
}

model CitationLedger {
  id                      String        @id @default(uuid()) @db.Uuid
  bookId                  String        @db.Uuid
  ledgerFingerprint       String
  finalVersionsFingerprint String
  sourceLedgerFingerprint String
  policyVersion           String
  citationStyle           CitationStyle
  entriesJson             Json
  chapterAuditIdsJson     Json
  lockedAt                DateTime      @default(now())
  createdByUserId         String?       @db.Uuid
  createdAt               DateTime      @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([bookId, ledgerFingerprint])
  @@index([bookId, lockedAt])
}

model SourceVerificationResult {
  id                      String                    @id @default(uuid()) @db.Uuid
  bookId                  String                    @db.Uuid
  chapterKey              String
  artifactVersionId       String                    @db.Uuid
  evidenceKind            SourceEvidenceKind
  evidenceRecordId        String
  sourceRecordId          String                    @db.Uuid
  workflowRunId           String?                   @db.Uuid
  policyVersion           String
  sourceFingerprint       String
  claimFingerprint        String
  inputFingerprint        String
  verificationFingerprint String
  verdict                 SourceVerificationVerdict
  supportingExcerpt       String?
  contradictingExcerpt    String?
  reasonCodesJson         Json                      @default("[]")
  correctionsJson         Json                      @default("[]")
  notes                    String?
  createdAt                DateTime                  @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  admissionReviews SourceAdmissionReview[]
  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Restrict)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@unique([artifactVersionId, evidenceKind, evidenceRecordId, verificationFingerprint], map: "SourceVerificationResult_version_kind_record_fingerprint_key")
  @@index([bookId, chapterKey, artifactVersionId], map: "SourceVerificationResult_book_chapter_version_idx")
  @@index([verificationFingerprint, verdict], map: "SourceVerificationResult_fingerprint_verdict_idx")
  @@index([inputFingerprint, createdAt], map: "SourceVerificationResult_inputFingerprint_created_idx")
  @@index([workflowRunId], map: "SourceVerificationResult_workflowRunId_idx")
}

model SourceAdmissionReview {
  id                      String                  @id @default(uuid()) @db.Uuid
  bookId                  String                  @db.Uuid
  chapterKey              String
  artifactVersionId       String                  @db.Uuid
  evidenceKind            SourceEvidenceKind
  evidenceRecordId        String
  verificationResultId    String?                 @db.Uuid
  verificationFingerprint String
  decision                SourceAdmissionDecision
  reviewerUserId          String?                 @db.Uuid
  notes                   String?
  createdAt               DateTime                @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  verificationResult SourceVerificationResult? @relation(fields: [verificationResultId], references: [id], onDelete: SetNull)
  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Restrict)
  reviewer User? @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([bookId, chapterKey, artifactVersionId, createdAt], map: "SourceAdmissionReview_book_chapter_version_created_idx")
  @@index([evidenceKind, evidenceRecordId, createdAt], map: "SourceAdmissionReview_kind_record_created_idx")
  @@index([verificationFingerprint, createdAt], map: "SourceAdmissionReview_fingerprint_created_idx")
  @@index([verificationResultId], map: "SourceAdmissionReview_verificationResultId_idx")
  @@index([reviewerUserId], map: "SourceAdmissionReview_reviewerUserId_idx")
}

model Decision {
  id              String       @id @default(uuid()) @db.Uuid
  bookId          String       @db.Uuid
  stageId         String       @db.Uuid
  artifactId      String?      @db.Uuid
  decisionType    DecisionType
  decisionValue   String
  notes           String?
  metadataJson    Json         @default("{}")
  createdByUserId String       @db.Uuid
  createdAt       DateTime     @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stage     BookStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  artifact  Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([bookId, stageId, createdAt])
}

model WorkflowRun {
  id             String            @id @default(uuid()) @db.Uuid
  bookId         String            @db.Uuid
  stageId        String            @db.Uuid
  runType        WorkflowRunType   @default(GENERAL)
  status         WorkflowRunStatus @default(QUEUED)
  inputJson      Json              @default("{}")
  outputJson     Json              @default("{}")
  errorText      String?
  idempotencyKey String?
  attempt        Int               @default(0)
  maxAttempts    Int               @default(1)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  heartbeatAt    DateTime?
  canceledAt     DateTime?
  cancelReason   String?
  startedAt      DateTime          @default(now())
  finishedAt     DateTime?
