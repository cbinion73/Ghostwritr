model LLMCallLog {
  id                   String   @id @default(uuid()) @db.Uuid
  requestId            String?
  providerRequestId    String?
  bookId               String   @db.Uuid
  workflowRunId        String?  @db.Uuid
  /// The chapter this call was actually working on, when applicable (e.g.
  /// "the-problem-becomes-visible-chapter-2"). Null for book-level calls
  /// (Promise, Outline, Base Story, Editing, etc.) that aren't scoped to one
  /// chapter. Populated via the ambient LLMCallContext for background
  /// workflows, or passed directly by the conversational chat routes.
  chapterKey           String?
  stageKey             String?
  stageRole            String
  operation            String   @default("unknown")
  attempt              Int      @default(1)
  provider             String
  model                String
  generationMode       String   @default("unknown")
  status               String   @default("SUCCEEDED")
  errorCode            String?
  errorMessage         String?
  promptTokens         Int
  completionTokens     Int
  totalTokens          Int
  /// Anthropic prompt-caching breakdown. promptTokens remains the TOTAL input
  /// (uncached + cacheCreation + cacheRead) to match LangChain usage_metadata.
  cacheCreationTokens  Int      @default(0)
  cacheReadTokens      Int      @default(0)
  reasoningInputTokens Int      @default(0)
  reasoningOutputTokens Int     @default(0)
  costUsd              Decimal  @db.Decimal(10, 6)
  searchCostUsd        Decimal  @default(0) @db.Decimal(10, 6)
  pricingVersion       String   @default("2026-07-13.pricing-table-v1")
  durationMs           Int
  createdAt            DateTime @default(now())

  @@index([bookId, createdAt])
  @@index([bookId, stageRole])
  @@index([bookId, stageKey])
  @@index([bookId, status])
  @@index([requestId])
  @@index([bookId, chapterKey])
  @@index([workflowRunId, createdAt])
}

/// Author Profile - Persistent author information across books
/// Stores background, writing preferences, constraints, and brand voice
/// Linked to User and optionally to BookSetupProfile for personalization
model AuthorProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String?   @db.Uuid

  // Core Information
  displayName           String    // How author wants to be called
  backgroundSummary     String?   // 200-300 word biography/background
  expertise             Json      @default("[]")  // Array of expertise areas
  targetAudience        String?   // Description of typical audience

  // Writing Preferences
  tonePreference        String?   // e.g., "Direct, practical, slightly irreverent"
  proseStyle            String?   // e.g., "Clear structure, avoid flowery language"
  preferredMetaphors    Json      @default("[]")  // Array of preferred metaphor types

  // Values & Constraints
  avoidPatterns         Json      @default("[]")  // Array of things to avoid
  mustInclude           Json      @default("[]")  // Array of things to always include
  brandVoice            String?   // Overall brand voice description

  // Multi-Book Consistency (for series/related books)
  characterNames        Json      @default("[]")  // Array of character names (consistency across books)
  terminology           Json      @default("[]")  // Array of custom glossary terms
  recurringMetaphors    Json      @default("[]")  // Array of metaphors to repeat
  styleGuideNotes       String?   // Custom formatting, structure notes

  // Metadata
  isDefault             Boolean   @default(false) // Can have multiple profiles, one default
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isDefault])
}
